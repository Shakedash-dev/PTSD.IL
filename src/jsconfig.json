{
  "compilerOptions": {
    "baseUrl": ".",
    "paths": {
      "@/*": ["./*"],
      "turndown": ["./types/turndown-shim.d.ts"]
    },
    "jsx": "react-jsx",
    "module": "esnext",
    "moduleResolution": "bundler",
    "lib": ["esnext", "dom"],
    "target": "esnext",
    "checkJs": true,
    "skipLibCheck": true,
    "allowSyntheticDefaultImports": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "types": ["vite/client"]
  },
  "include": [
    "App.jsx",
    "main.jsx",
    "pages/**/*.jsx",
    "pages/**/*.js",
    "components/**/*.jsx",
    "components/**/*.js",
    "contexts/**/*.jsx",
    "contexts/**/*.js",
    "lib/**/*.js",
    "lib/**/*.jsx",
    "api/**/*.js",
    "types/**/*.d.ts"
  ],
  "exclude": ["node_modules", "dist", "vite-plugins", "components/ui"]
} 